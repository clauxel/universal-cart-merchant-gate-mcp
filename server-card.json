{
  "name": "universalcartmerchantgate",
  "title": "Universal Cart Merchant Gate",
  "description": "A paid remote MCP for Universal Cart merchant readiness MCP, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://universalcartmerchantgate.clauxel.com/",
